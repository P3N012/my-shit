# Copy to .env and edit. .env is gitignored.

# --- Required ---------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://insight:insight@localhost:5432/insight

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ACCESS_TOKEN_SECRET=replace-me
REFRESH_TOKEN_SECRET=replace-me

# --- Optional ---------------------------------------------------------------
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
PROJECT_NAME=InsightPlus

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# Comma-separated. Never use * with allow_credentials=true.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

HOST=0.0.0.0
PORT=8000

LOG_LEVEL=INFO

# Per-IP rate limits (slowapi syntax: "<count>/<window>")
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_REFRESH=20/minute
RATE_LIMIT_AI=30/minute

# --- AI -----------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=4096
AI_ENABLED=true

# Redis (background job queue for /ai/jobs)
REDIS_URL=redis://localhost:6379/0

# --- Stripe Connect -----------------------------------------------------
# Your platform's secret key (sk_test_... in development).
# Used to exchange OAuth codes for connected-account access tokens.
STRIPE_SECRET_KEY=

# Stripe Connect client ID (ca_...). Get from:
# Stripe Dashboard → Settings → Connect → "Get your client ID"
STRIPE_CONNECT_CLIENT_ID=

# Must exactly match a Redirect URI configured in your Stripe Connect
# settings, including scheme and trailing slash (or lack thereof).
STRIPE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/connections/stripe/callback

# Frontend URLs the callback redirects to. Pre-encoded query string;
# the callback appends &connection_id=... or &reason=... before redirect.
STRIPE_OAUTH_SUCCESS_URL=http://localhost:3000/connections?stripe=ok
STRIPE_OAUTH_FAILURE_URL=http://localhost:3000/connections?stripe=error
